# Copy to docker-compose.yml, customise if needed, then:
#   podman compose up -d --build      (docker compose up -d --build works too)
services:
  tsugi:
    build:
      context: .
      dockerfile: Containerfile
    image: tsugi:latest
    # Single sign-on (OpenID Connect). On by default — set DISABLE_SSO=1 to turn it
    # off. Register an OIDC client in your identity provider with redirect URI
    # https://tsugi.example.com/auth/oidc/callback and scopes: openid profile groups.
    # environment:
    #   OIDC_ISSUER: "https://sso.example.com"
    #   OIDC_CLIENT_ID: "tsugi"
    #   OIDC_CLIENT_SECRET: "change-me"
    #   SESSION_SECRET: "change-me"          # e.g. openssl rand -hex 32
    #   PUBLIC_BASE_URL: "https://tsugi.example.com"
    #   # DISABLE_SSO: "1"
    ports:
      - "9000:9000"
    volumes:
      # Default: isolated named volume — the image stays code-only.
      - tsugi-data:/data
      # To run against an existing host data dir instead, comment out the line
      # above, uncomment the bind mount below, and uncomment userns_mode.
      # `keep-id` is podman-rootless only (drop it on Docker); it maps the
      # container's user onto yours so writes to the bind mount succeed.
      # - ./data:/data
    # userns_mode: keep-id
    restart: unless-stopped

volumes:
  tsugi-data:
