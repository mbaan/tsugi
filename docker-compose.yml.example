# Copy to docker-compose.yml, customise if needed, then:
#   podman compose up -d --build      (docker compose up -d --build works too)
services:
  tsugi:
    build:
      context: .
      dockerfile: Containerfile
    image: tsugi:latest
    ports:
      - "9000:9000"
    volumes:
      # Default: isolated named volume — the image stays code-only.
      - tsugi-data:/data
      # To run against an existing host data dir instead, comment out the line
      # above, uncomment the bind mount below, and uncomment userns_mode.
      # `keep-id` is podman-rootless only (drop it on Docker); it maps the
      # container's user onto yours so writes to the bind mount succeed.
      # - ./data:/data
    # userns_mode: keep-id
    restart: unless-stopped

volumes:
  tsugi-data:
